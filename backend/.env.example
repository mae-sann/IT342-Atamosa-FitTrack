# backend/.env.example
# Database
DB_URL=jdbc:postgresql://your-supabase-host:5432/postgres
DB_USERNAME=your-supabase-username
DB_PASSWORD=your-supabase-password

# Supabase
SUPABASE_PROJECT_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# JWT
JWT_SECRET=your-jwt-secret-key-min-256-bits
JWT_EXPIRATION_MS=86400000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# SMTP Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=no-reply@fittrack.app

# Optional tuning
DB_MAX_POOL_SIZE=5
DB_MIN_IDLE=1
DB_CONNECTION_TIMEOUT_MS=30000
JPA_DDL_AUTO=update
CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*,http://localhost:3000