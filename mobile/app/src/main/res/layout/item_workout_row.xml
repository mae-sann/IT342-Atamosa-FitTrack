<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="14dp"
    android:layout_marginBottom="8dp">

    <!-- Row 1: Workout Name -->
    <TextView
        android:id="@+id/tvWorkoutName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Workout Name"
        android:textColor="@color/colorTextPrimary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <!-- Row 2: Date + Category badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvWorkoutDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Feb 20, 2026"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tvWorkoutCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_blue"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="Upper Body"
            android:textColor="@color/colorUpperBodyText"
            android:textSize="11sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Row 3: Exercise count -->
    <TextView
        android:id="@+id/tvExerciseCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3 exercises"
        android:textColor="@color/colorTextPrimary"
        android:textSize="14sp"
        android:textStyle="bold"/>

    <!-- Row 4: Exercise names preview -->
    <TextView
        android:id="@+id/tvExerciseNames"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Bench Press · Pull-Ups · Shoulder Press"
        android:textColor="@color/colorTextSecondary"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- Row 5: Edit + Delete buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="end">

        <Button
            android:id="@+id/btnEditWorkout"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Edit"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:stateListAnimator="@null"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnDeleteWorkout"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_button_danger"
            android:text="Delete"
            android:textColor="@color/colorError"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:stateListAnimator="@null"/>

    </LinearLayout>

</LinearLayout>