<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="10dp">

    <!-- Goal text + status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvGoalText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Bench Press 80 kg"
            android:textColor="@color/colorTextPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvGoalStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_blue"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="In Progress"
            android:textColor="@color/colorUpperBodyText"
            android:textSize="11sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Progress bar track -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:background="@drawable/bg_progress_track"
        android:layout_marginBottom="8dp">

        <View
            android:id="@+id/viewGoalProgress"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_progress_fill_blue"/>
    </FrameLayout>

    <!-- Current / % / Target -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvGoalCurrent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="60 current"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tvGoalPct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="75%"
            android:textColor="@color/colorTextPrimary"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvGoalTarget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="80 target"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:gravity="end"/>
    </LinearLayout>

    <!-- Update + Delete buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnUpdateGoal"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_secondary"
            android:text="Update Progress"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:stateListAnimator="@null"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnDeleteGoal"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_button_danger"
            android:text="Delete"
            android:textColor="@color/colorError"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:stateListAnimator="@null"/>
    </LinearLayout>

</LinearLayout>