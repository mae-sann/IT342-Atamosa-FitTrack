<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Top spacing -->
        <View android:layout_width="0dp"
            android:layout_height="48dp"/>

        <!-- Logo -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp">
            <View
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_avatar"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="⚡"
                android:textSize="28sp"/>
        </FrameLayout>

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="FITTRACK"
            android:textColor="@color/colorTextPrimary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"/>

        <!-- Heading -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Welcome Back"
            android:textColor="@color/colorTextPrimary"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Log in to continue your fitness journey"
            android:textColor="@color/colorTextSecondary"
            android:textSize="14sp"/>

        <!-- Card container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Email label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <!-- Email input -->
            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:hint="you@example.com"
                android:textColor="@color/colorTextPrimary"
                android:textColorHint="@color/colorTextMuted"
                android:textSize="14sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="textEmailAddress"
                android:singleLine="true"/>

            <!-- Password label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"/>

            <!-- Password input -->
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:hint="••••••••"
                android:textColor="@color/colorTextPrimary"
                android:textColorHint="@color/colorTextMuted"
                android:textSize="14sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="textPassword"
                android:singleLine="true"/>

            <!-- Error message -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text=""
                android:textColor="@color/colorError"
                android:textSize="13sp"
                android:visibility="gone"/>

            <!-- Loading bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:visibility="gone"/>

            <!-- Login Button -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_button_primary"
                android:text="Log In"
                android:textColor="@color/colorWhite"
                android:textSize="15sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"/>

            <!-- OR divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/colorDivider"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:text="or"
                    android:textColor="@color/colorTextMuted"
                    android:textSize="12sp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/colorDivider"/>
            </LinearLayout>

            <!-- Google Button -->
            <Button
                android:id="@+id/btnGoogle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_google"
                android:text="Continue with Google"
                android:textColor="#1f2937"
                android:textSize="14sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"/>

            <!-- Register link -->
            <TextView
                android:id="@+id/tvRegisterLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:text="Don\'t have an account? Create one free →"
                android:textColor="@color/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Bottom spacing -->
        <View android:layout_width="0dp"
            android:layout_height="32dp"/>

    </LinearLayout>
</ScrollView>