<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvUpdateGoalName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Goal Name"
        android:textColor="@color/colorTextPrimary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvUpdateTarget"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Target: 100"
        android:textColor="@color/colorTextSecondary"
        android:textSize="13sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Current Value"
        android:textColor="@color/colorTextPrimary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etNewCurrentValue"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Enter new value"
        android:textSize="14sp"
        android:inputType="numberDecimal"
        android:singleLine="true"
        android:background="@drawable/bg_input_field"
        android:textColor="@color/colorTextPrimary"
        android:textColorHint="@color/colorTextMuted"/>

</LinearLayout>