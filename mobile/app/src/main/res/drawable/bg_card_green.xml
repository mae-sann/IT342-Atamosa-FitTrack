<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#111827"/>
            <stroke android:width="1dp" android:color="#1f2937"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item android:bottom="3dp" android:left="0dp"
        android:right="0dp" android:top="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#10B981"/>
            <corners android:topLeftRadius="16dp"
                android:topRightRadius="16dp"/>
        </shape>
    </item>
    <item android:top="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#111827"/>
            <corners android:bottomLeftRadius="16dp"
                android:bottomRightRadius="16dp"/>
        </shape>
    </item>
</layer-list>